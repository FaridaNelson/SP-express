# ─── StudioPulse API Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
#
# In production, MONGODB_URI and JWT_SECRET are loaded from
# Google Secret Manager (see GCP setup commands below).
# ─────────────────────────────────────────────────────────────────────

# App
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development
PORT=4000

# MongoDB connection string
# Dev: point to your local or Atlas dev cluster
# Prod: stored in Google Secret Manager as "MONGODB_URI"
MONGODB_URI=mongodb://localhost:27017/studiopulse-dev

# JWT signing secret — MUST be at least 32 characters
# Generate a strong one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Example (do NOT use this — generate your own):
#   JWT_SECRET=k8Tz3xR9mWvQ7pLsYdFjN4bHcA6eUiOgK2rXtZwJy5aDfGhMnSqVuCxBoPl
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_at_least_32_chars

# JWT token lifetime in days
JWT_DAYS=7

# ─── Google Secret Manager (production only) ────────────────────────
# Set GCP_PROJECT_ID so the app knows which project to fetch secrets from.
# GCP_PROJECT_ID=your-gcp-project-id
#
# Create the secrets in GCP:
#
#   gcloud secrets create MONGODB_URI --replication-policy="automatic"
#   echo -n "mongodb+srv://user:pass@cluster.mongodb.net/dbname" | \
#     gcloud secrets versions add MONGODB_URI --data-file=-
#
#   gcloud secrets create JWT_SECRET --replication-policy="automatic"
#   node -e "process.stdout.write(require('crypto').randomBytes(48).toString('base64'))" | \
#     gcloud secrets versions add JWT_SECRET --data-file=-
#
# Grant your Cloud Run service account access:
#
#   gcloud secrets add-iam-policy-binding MONGODB_URI \
#     --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#     --role="roles/secretmanager.secretAccessor"
#
#   gcloud secrets add-iam-policy-binding JWT_SECRET \
#     --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#     --role="roles/secretmanager.secretAccessor"
# ─────────────────────────────────────────────────────────────────────
